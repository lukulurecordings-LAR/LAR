# Canonical app origin
PUBLIC_SITE_URL=

# Supabase project and Auth browser configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-only Supabase Data API credential. Prefer a new sb_secret_ key.
SUPABASE_URL=
SUPABASE_SECRET_KEY=
# Legacy fallback only; do not configure when SUPABASE_SECRET_KEY is set.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only Stripe key. Prefer a least-privilege restricted key.
STRIPE_RESTRICTED_KEY=
# Legacy fallback only; do not configure when STRIPE_RESTRICTED_KEY is set.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Persistent Stripe Price IDs created separately in test and live mode
STRIPE_PRICE_PLAN_BASIC=
STRIPE_PRICE_PLAN_PRO=
STRIPE_PRICE_PLAN_VIP=
STRIPE_PRICE_STUDIO_RECORDING=
STRIPE_PRICE_STUDIO_MIXING=
STRIPE_PRICE_STUDIO_MASTERING=
STRIPE_PRICE_STUDIO_PODCAST=
STRIPE_PRICE_DESIGN_COVER=
STRIPE_PRICE_DESIGN_POSTER=
STRIPE_PRICE_DESIGN_VIDEO=
STRIPE_PRICE_DESIGN_ALBUM=
STRIPE_PRICE_DESIGN_SOCIAL=
STRIPE_PRICE_BEAT_INDLELA_BASIC=
STRIPE_PRICE_BEAT_INDLELA_PREMIUM=
STRIPE_PRICE_BEAT_RIOT_BASIC=
STRIPE_PRICE_BEAT_RIOT_PREMIUM=
STRIPE_PRICE_BEAT_MELO_BASIC=
STRIPE_PRICE_BEAT_MELO_PREMIUM=
STRIPE_PRICE_BEAT_LUKULU_TAPES_BASIC=
STRIPE_PRICE_BEAT_LUKULU_TAPES_PREMIUM=
